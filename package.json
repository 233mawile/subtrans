  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./processorTypes": "./src/processorTypes/index.ts"
  },
  "imports": {
    "#core": "./src/core/index.ts",
    "#processorTypes": "./src/processorTypes/index.ts",
